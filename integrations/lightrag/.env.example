# Copia como .env y completa solo en tu entorno local.
# Nunca subas .env al repositorio.

HOST=0.0.0.0
PORT=9621

# Configura el proveedor LLM según la documentación oficial de LightRAG.
# Para entornos locales puede utilizarse Ollama cuando sea compatible
# con la configuración elegida.

# LLM_BINDING=ollama
# LLM_MODEL=qwen3:8b
# LLM_BINDING_HOST=http://host.docker.internal:11434

# EMBEDDING_BINDING=ollama
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_BINDING_HOST=http://host.docker.internal:11434
